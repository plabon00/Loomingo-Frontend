# -----------------------------------------------------------------------------
# NEXT.JS FRONTEND ENVIRONMENT VARIABLES
# -----------------------------------------------------------------------------

# NEXT_PUBLIC_API_URL: The URL of the main Loomingo backend.
NEXT_PUBLIC_API_URL=https://loomingo.vercel.app

# NEXT_PUBLIC_INVOICE_SERVICE_URL: The URL of the Invoice Microservice.
# (Must be provided to fetch and generate invoices)
NEXT_PUBLIC_INVOICE_SERVICE_URL=https://invoice-microservice.vercel.app
